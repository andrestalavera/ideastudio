@inherits LayoutComponentBase
@using IdeaStudio.Website.Services
@using IdeaStudio.Website.Components
@inject ICultureService CultureService
@inject ILocalizationService LocalizationService
@inject ILocalizedRoute LocalizedRoute
@implements IDisposable

<CascadingValue Value="this">
    <div id="main-content-container" class="ds-app">
        <a href="#main-content" class="ds-skip-link">@skipToMainContentText</a>

        <header class="ds-header ds-print-hidden">
            <div class="ds-container ds-header__inner">
                <a class="ds-header__logo" href="@LocalizedRoute.For("home")">IdeaStud.io</a>
                <nav class="ds-header__nav" aria-label="Main">
                    <a href="@LocalizedRoute.For("services.hub")">@servicesText</a>
                    <a href="@LocalizedRoute.For("realisations")">@realisationsText</a>
                    <a href="@LocalizedRoute.For("cv")">@cvText</a>
                </nav>
                <div class="ds-header__actions">
                    <CultureSelector />
                    <a class="ds-btn ds-btn--primary ds-btn--sm"
                       href="https://calendly.com/andres-talavera/30min"
                       target="_blank" rel="noopener"
                       aria-label="@bookCallAriaText">
                        @bookCallText
                    </a>
                </div>
            </div>
        </header>

        <main id="main-content" role="main">
            @Body
        </main>

        <FooterSection />
    </div>
</CascadingValue>

@code {
    [Parameter] public RenderFragment? NavbarContent { get; set; }

    private string skipToMainContentText = "Skip to main content";
    private string servicesText = "Services";
    private string realisationsText = "Projects";
    private string cvText = "Resume";
    private string bookCallText = "Book 30 min";
    private string bookCallAriaText = "Book a 30-minute call on Calendly (opens in a new tab)";

    protected override async Task OnInitializedAsync()
    {
        CultureService.CultureChanged += OnCultureChanged;
        await LoadLocalizedStringsAsync();
    }

    public void SetNavbarContent(RenderFragment? content)
    {
        NavbarContent = content;
        StateHasChanged();
    }

    private async Task LoadLocalizedStringsAsync()
    {
        await LocalizationService.LoadCultureAsync(CultureService.CurrentCulture.Name);
        LoadTexts();
        StateHasChanged();
    }

    private void OnCultureChanged() => _ = SafeLoadLocalizedStringsAsync();

    private async Task SafeLoadLocalizedStringsAsync()
    {
        try
        {
            await LoadLocalizedStringsAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[MainLayout] Failed to load culture: {ex.Message}");
        }
    }

    private void LoadTexts()
    {
        skipToMainContentText = LocalizationService.GetString("SkipToMainContent");
        LoadNavTexts();
    }

    private void LoadNavTexts()
    {
        servicesText = LocalizationService.GetString("Nav.Services");
        realisationsText = LocalizationService.GetString("Nav.Realisations");
        cvText = LocalizationService.GetString("Nav.Cv");
        bookCallText = LocalizationService.GetString("Nav.BookCall");
    }

    public void Dispose()
    {
        CultureService.CultureChanged -= OnCultureChanged;
        GC.SuppressFinalize(this);
    }
}
