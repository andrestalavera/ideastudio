@inherits LayoutComponentBase
@using IdeaStudio.Website.Services
@using IdeaStudio.Website.Components
@inject ICultureService CultureService
@inject ILocalizationService LocalizationService
@inject NavigationManager Navigation
@inject ISceneTheme SceneTheme
@inject IConsentService Consent
@inject IAnalyticsService Analytics
@implements IDisposable

<CascadingValue Value="this">
    <GlCanvas />
    <a href="#main-content" class="ds-skip-link">@skipToMainContentText</a>
    <Progress />
    <Masthead />

    <main id="main-content" role="main">
        @Body
    </main>

    @if (showCta)
    {
        <CtaBand />
    }
    <Footer />
    <CookieBanner />
</CascadingValue>

@code {
    private string skipToMainContentText = "Skip to main content";
    private bool showCta = true;
    private bool runtimeInitialized;

    protected override async Task OnInitializedAsync()
    {
        CultureService.CultureChanged += OnCultureChanged;
        Navigation.LocationChanged += OnLocationChanged;
        await LoadLocalizedStringsAsync();
        UpdateCtaVisibility(Navigation.Uri);
        await Consent.LoadAsync();
        Consent.OnChanged += OnConsentChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || runtimeInitialized) return;
        runtimeInitialized = true;
        try { await SceneTheme.InitializeAsync(); }
        catch (Microsoft.JSInterop.JSDisconnectedException) { /* runtime gone */ }

        // The cinema bundle is now loaded; flush the initial consent state to it.
        if (Consent.HasDecided)
        {
            await Analytics.SetConsentAsync(Consent.IsGranted);
        }
    }

    private async Task LoadLocalizedStringsAsync()
    {
        await LocalizationService.LoadCultureAsync(CultureService.CurrentCulture.Name);
        skipToMainContentText = LocalizationService.GetString("SkipToMainContent");
        StateHasChanged();
    }

    private void OnCultureChanged() => _ = SafeLoadLocalizedStringsAsync();

    private async Task SafeLoadLocalizedStringsAsync()
    {
        try { await LoadLocalizedStringsAsync(); }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[MainLayout] Failed to load culture: {ex.Message}");
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateCtaVisibility(e.Location);
        StateHasChanged();
        _ = Analytics.TrackPageViewAsync(e.Location);
    }

    private void OnConsentChanged()
    {
        _ = Analytics.SetConsentAsync(Consent.IsGranted);
    }

    private void UpdateCtaVisibility(string uri)
    {
        Uri absolute = new(uri);
        string path = absolute.AbsolutePath.ToLowerInvariant();
        showCta = !(path.Contains("mentions-legales") || path.Contains("/legal")
                    || path.Contains("confidentialite") || path.Contains("/privacy"));
    }

    public void Dispose()
    {
        CultureService.CultureChanged -= OnCultureChanged;
        Navigation.LocationChanged -= OnLocationChanged;
        Consent.OnChanged -= OnConsentChanged;
        GC.SuppressFinalize(this);
    }
}
