@page "/fr/faq"
@page "/en/faq"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@inject ILocalizedRoute LocalizedRoute
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription"
         Author="Andrés Talavera"
         CanonicalUrl="@seoCanonical" Locale="@seoLocale"
         HreflangUrls="@LocalizedRoute.Alternates("faq")"
         SiteName="IdeaStud.io"
         OgImage="https://ideastud.io/images/andres-talavera.jpeg" OgImageAlt="Andrés Talavera"
         StructuredData="@seoStructuredData"
         SpeakableSelectors="@speakable" />

<Hero Kicker="@heroKicker" Title="@heroTitle" Lead="@heroLead" />

@foreach (FaqGroup group in groups)
{
    <PageSection Width="narrow">
        <ChapterBand Title="@group.Title" />
        <div class="mt-chapter">
            <FaqAccordion Items="@group.Items" />
        </div>
    </PageSection>
}

@* Still have a question? → contact *@
<PageSection Width="narrow">
    <div class="ds-rhythm" data-reveal>
        <p class="ds-kicker">@stillKicker</p>
        <h2 class="ds-title">@stillTitle</h2>
        <div class="row mt-8">
            <ButtonLink Href="https://calendly.com/andres-talavera/30min" Variant="primary" External="true" Arrow="→" Label="@bookCta" />
            <ButtonLink Href="@LocalizedRoute.For("contact")" Label="@contactCta" />
        </div>
    </div>
</PageSection>

@code {
    private sealed record FaqGroup(string Title, IReadOnlyList<(string Q, string A)> Items);

    private List<FaqGroup> groups = new();
    private string seoTitle = "FAQ, IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/faq";
    private string seoLocale = "fr_FR";
    private string heroKicker = "FAQ";
    private string heroTitle = "Vos questions, mes réponses.";
    private string heroLead = "";
    private string stillKicker = "Encore une question ?";
    private string stillTitle = "Écrivez-moi, je réponds vite.";
    private string contactCta = "Décrire mon projet";
    private string bookCta = "Réserver un appel";
    private List<string>? seoStructuredData;
    private List<string> speakable = new() { ".ds-hero .ds-display", ".ds-hero .ds-lead" };

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        seoCanonical = fr ? "https://ideastud.io/fr/faq" : "https://ideastud.io/en/faq";
        seoTitle = fr ? "FAQ, Tarifs, missions, formations | IdeaStud.io" : "FAQ, Rates, engagements, training | IdeaStud.io";
        heroTitle = fr ? "Vos questions, mes réponses." : "Your questions, answered.";
        heroLead = fr
            ? "Tarifs, façon de travailler, formations, IA, l'essentiel pour savoir si on est faits pour collaborer."
            : "Rates, how I work, training, AI, the essentials to know whether we're a fit.";
        seoDescription = heroLead;

        stillKicker = fr ? "Encore une question ?" : "Still have a question?";
        stillTitle = fr ? "Écrivez-moi, je réponds vite." : "Drop me a message, I reply fast.";
        contactCta = fr ? "Décrire mon projet" : "Describe my project";
        bookCta = fr ? "Réserver un appel" : "Book a call";

        groups = fr ? BuildFr() : BuildEn();
        GenerateStructuredData();
    }

    private static List<FaqGroup> BuildFr() => new()
    {
        new("Travailler ensemble", new (string, string)[]
        {
            ("Quels projets acceptez-vous ?", "Conseil, techlead, formation, accompagnement IA, ou réalisations sur-mesure, .NET, Azure, mobile, web. Si le cadrage est clair et le délai sain, j'y vais."),
            ("Quels sont vos tarifs ?", "Tarif journalier à partir de 600 € (conseil, techlead) et 800 € (formation, IA en entreprise), ajusté selon la durée, la complexité et le niveau d'implication. Premier échange de 30 minutes offert, devis chiffré sous 24 h."),
            ("Où pouvez-vous intervenir ?", "Lyon, Paris, Genève, Fribourg, sur site, hybride ou full-remote selon votre besoin. Je me déplace pour les kick-offs, les ateliers techniques et les sessions de formation."),
            ("Comment travaille-t-on ensemble ?", "En portage salarial via OpenWork (société française) : un cadre contractuel simple et sécurisé pour vous comme pour moi. Facturation en EUR par défaut, CHF possible pour les missions côté suisse."),
            ("Sous quel délai pouvez-vous démarrer ?", "Un appel de cadrage sous quelques jours, un devis sous 24 h après un brief court. Les missions courtes démarrent généralement sous une à deux semaines selon mon planning."),
            ("Je préfère écrire plutôt qu'appeler, c'est possible ?", "Oui. Le formulaire de contact suffit pour un premier échange : décrivez votre besoin, je reviens vers vous rapidement avec une proposition ou des questions."),
            ("À qui appartient le code produit ?", "À vous, entièrement. Le code, les comptes et l'infrastructure créés pendant la mission vous reviennent, avec la documentation pour que vos équipes prennent le relais sans dépendre de moi."),
            ("Où sont hébergées mes données ?", "Là où vous le souhaitez : en Europe par défaut (France, Suisse) pour rester conforme au RGPD, ou sur votre propre infrastructure. Je conçois les projets pour que vous ne soyez jamais prisonnier d'un hébergeur."),
        }),
        new("Formation", new (string, string)[]
        {
            ("Quelles formations dispensez-vous ?", "Vingt modules au catalogue, regroupés en quatre familles : .NET, Azure, IA & vibe coding, architecture & DevOps. Chaque module se décline en inter-entreprise ou en intra sur-mesure."),
            ("Formez-vous à distance ?", "Oui, classe virtuelle synchrone, exercices en binôme, démos en partage d'écran, retours en direct. La même rigueur qu'en présentiel."),
            ("Les formations sont-elles finançables ?", "Oui. Les centres partenaires (ORSYS, IP-Formation, NextFormation) sont Qualiopi : OPCO, CPF entreprise, plan de développement des compétences. Côté contenu, 15+ ans de pratique .NET/Azure et 3 000+ heures de formation dispensées."),
        }),
        new("IA & technique", new (string, string)[]
        {
            ("Comment garantissez-vous la qualité avec l'IA ?", "Aucune ligne générée n'est livrée sans relecture. Je raisonne, je vérifie, je corrige, la vitesse de l'IA n'a de valeur que si elle ne crée pas de dette cachée."),
            ("Pouvez-vous installer l'IA en interne ?", "Oui : des modèles d'IA open source hébergés sur vos propres serveurs, et des passerelles sur-mesure qui connectent vos outils d'IA à vos applications. Vos données ne sortent jamais de chez vous. Voir le service « IA en entreprise »."),
            ("Pouvez-vous rendre mon site visible des IA ?", "Oui. J'optimise votre site pour qu'il soit compris et cité par les IA (ChatGPT, Perplexity, Gemini), exactement l'approche utilisée sur ce site, qui apparaît déjà dans leurs réponses."),
        }),
    };

    private static List<FaqGroup> BuildEn() => new()
    {
        new("Working together", new (string, string)[]
        {
            ("What projects do you take on?", "Consulting, tech-lead, training, AI enablement, or custom delivery, .NET, Azure, mobile, web. If the scope is clear and the timeline sane, I'm in."),
            ("What are your rates?", "Day rate from 600 € (consulting, tech-lead) and 800 € (training, enterprise AI). Adjusted for duration, complexity and level of involvement. First 30-minute call is free, a quote within 24h."),
            ("Where do you work?", "Lyon, Paris, Geneva, Fribourg, on-site, hybrid or fully remote depending on your need. I travel for kick-offs, technical workshops and training sessions."),
            ("How do we work together?", "Via French wage-portage company OpenWork: a simple, secure contractual frame for both sides. Default invoicing in EUR, CHF available for Swiss assignments."),
            ("How fast can you start?", "A scoping call within days, a quote within 24h of a short brief. Short engagements typically start within one to two weeks depending on my schedule."),
            ("Can I just message you instead of booking a call?", "Yes. The contact form is enough for a first exchange: describe your need and I'll get back to you quickly with a proposal or questions."),
            ("Who owns the code you produce?", "You do, fully. The code, accounts and infrastructure created during the engagement are yours, with documentation so your team can take over without depending on me."),
            ("Where is my data hosted?", "Wherever you want: in Europe by default (France, Switzerland) to stay GDPR-compliant, or on your own infrastructure. I design projects so you're never locked into one host."),
        }),
        new("Training", new (string, string)[]
        {
            ("What trainings do you deliver?", "Twenty catalogue modules across four families: .NET, Azure, AI & vibe coding, architecture & DevOps. Each runs as inter-company or bespoke in-house."),
            ("Do you train remotely?", "Yes, synchronous virtual classroom, pair exercises, screen-share demos, live feedback. Same rigour as on-site."),
            ("Can the training be funded?", "Yes. Partner centres (ORSYS, IP-Formation, NextFormation) are Qualiopi-certified: OPCO, CPF entreprise, skills-development plans. On content, 15+ years of hands-on .NET/Azure and 3,000+ hours of training delivered."),
        }),
        new("AI & technical", new (string, string)[]
        {
            ("How do you keep quality with AI?", "No generated line ships without review. I reason, verify, correct, AI speed is only valuable if it doesn't create hidden debt."),
            ("Can you set up AI in-house?", "Yes: open-source AI models hosted on your own servers, plus custom bridges that connect your AI tools to your applications. Your data never leaves your premises. See the \"AI for the enterprise\" service."),
            ("Can you make my site visible to AIs?", "Yes. I optimize your site so it's understood and cited by AIs (ChatGPT, Perplexity, Gemini), exactly the approach used on this site, which already shows up in their answers."),
        }),
    };

    private void GenerateStructuredData()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        string cultureCode = fr ? "fr" : "en";

        SchemaOrg.BreadcrumbList breadcrumb = SchemaOrg.CreateBreadcrumb(
            "https://ideastud.io",
            (fr ? "Accueil" : "Home", LocalizedRoute.For("home", cultureCode)),
            ("FAQ", LocalizedRoute.For("faq", cultureCode)));

        SchemaOrg.Question[] questions = groups
            .SelectMany(g => g.Items)
            .Select(x => new SchemaOrg.Question(x.Q, new SchemaOrg.Answer(x.A)))
            .ToArray();

        SchemaOrg.FAQPage faqPage = new(questions);

        seoStructuredData = new List<string>
        {
            SchemaOrg.ToJsonLd(breadcrumb),
            SchemaOrg.ToJsonLd(faqPage)
        };
    }
}
