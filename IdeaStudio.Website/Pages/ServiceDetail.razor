@page "/fr/services/{slug}"
@page "/en/services/{slug}"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription" CanonicalUrl="@seoCanonical" Locale="@seoLocale" />

<Hero Kicker="— Service" Title="@titleText" Lead="@lead" />

@code {
    [Parameter] public string? Slug { get; set; }

    private string seoTitle = "Service";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/services";
    private string seoLocale = "fr_FR";
    private string titleText = "Service";
    private string lead = "";

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        string cultureSeg = fr ? "fr" : "en";
        seoCanonical = $"https://ideastud.io/{cultureSeg}/services/{Slug ?? string.Empty}";
        seoTitle = Slug is null ? (fr ? "Service" : "Service") : $"{Slug} — IdeaStud.io";
        titleText = Slug ?? (fr ? "Service" : "Service");
        lead = fr ? "Page service en construction (V3 phase 2)." : "Service page under construction (V3 phase 2).";
        seoDescription = lead;
    }
}
