@page "/fr/services/{slug}"
@page "/en/services/{slug}"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@using ServiceModel = IdeaStudio.Website.Models.Service
@inherits LocalizedComponent
@inject IContentGateway Content
@inject ILocalizedRoute LocalizedRoute
@inject ISlugTranslator SlugTranslator
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription"
         CanonicalUrl="@seoCanonical" Locale="@seoLocale"
         HreflangUrls="@seoHreflang"
         SiteName="IdeaStud.io"
         StructuredData="@seoStructuredData" />

@if (service is null)
{
    <Hero Kicker="404" Title="@notFoundTitle" Lead="@notFoundLead">
        <Actions>
            <ButtonLink Href="@LocalizedRoute.For("services.hub")" Variant="primary" Label="@backText" />
        </Actions>
    </Hero>
}
else
{
    <Hero Kicker="@service.Kicker" Title="@service.Title" Lead="@service.Tagline" />

    @* Summary *@
    <PageSection Rhythm="section" Bordered="false" Width="narrow">
        <p class="ds-lead" data-reveal>@service.Summary</p>
    </PageSection>

    @* Highlights *@
    @if (service.Highlights is { Count: > 0 })
    {
        <PageSection Width="narrow">
            <ChapterBand Kicker="@highlightsKicker" Title="@highlightsTitle" />
            <ul class="ds-highlight-list mt-8">
                @for (int i = 0; i < service.Highlights.Count; i++)
                {
                    <li class="ds-highlight" data-reveal style="@($"--reveal-step:{i}")">
                        <span class="ds-highlight-mark" aria-hidden="true"></span>
                        <span>@service.Highlights[i]</span>
                    </li>
                }
            </ul>
        </PageSection>
    }

    @* Use cases *@
    @if (service.UseCases is { Count: > 0 })
    {
        <PageSection>
            <ChapterBand Kicker="@useCaseKicker" Title="@useCaseTitle" />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mt-10">
                @for (int i = 0; i < service.UseCases.Count; i++)
                {
                    UseCase uc = service.UseCases[i];
                    <Card data-reveal style="@($"--reveal-step:{i}")">
                        <h3 class="card-title">@uc.Title</h3>
                        <p class="card-text">@uc.Description</p>
                    </Card>
                }
            </div>
        </PageSection>
    }

    @* Training centres (formateur only), shared editorial block with the CV page *@
    @if (IsTrainerService(service) && centers.Count > 0)
    {
        <PageSection>
            <ChapterBand Kicker="@centersKicker" Title="@centersTitle" />
            <p class="ds-lead mt-6" data-reveal>@centersIntro</p>
            <div class="mt-8">
                <TeachList Centers="@centers" />
            </div>
        </PageSection>
    }

    @* FAQ, expanded editorial Q&A *@
    @if (service.Faq is { Count: > 0 })
    {
        <PageSection Width="narrow">
            <ChapterBand Kicker="@faqKicker" Title="@faqTitle" />
            <div class="mt-10">
                @for (int i = 0; i < service.Faq.Count; i++)
                {
                    FaqEntry f = service.Faq[i];
                    <QABlock Kicker="@($"Q {i + 1:D2}")" Question="@f.Question" Answer="@f.Answer" Step="@i" />
                }
            </div>
        </PageSection>
    }

    @* Training catalogue (formateur only) *@
    @if (IsTrainerService(service) && trainings is { Count: > 0 })
    {
        <PageSection>
            <ChapterBand Kicker="@catalogueKicker" Title="@catalogueTitle" />
            <TrainingCatalogue Trainings="@trainings" />
        </PageSection>
    }
}

@code {
    [Parameter] public string? Slug { get; set; }

    private ServiceModel? service;
    private IReadOnlyList<Training> trainings = Array.Empty<Training>();
    private IReadOnlyList<TrainingCenter> centers = Array.Empty<TrainingCenter>();
    private string seoTitle = "Service, IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/services";
    private string seoLocale = "fr_FR";
    private Dictionary<string, string>? seoHreflang;
    private string highlightsKicker = "Le périmètre";
    private string highlightsTitle = "Ce que la mission couvre.";
    private string useCaseKicker = "Cas d'usage";
    private string useCaseTitle = "Quand on m'appelle.";
    private string faqKicker = "Questions fréquentes";
    private string faqTitle = "Ce que les clients demandent.";
    private string catalogueKicker = "Catalogue";
    private string catalogueTitle = "20 modules pour vos équipes.";
    private string centersKicker = "Partenaires";
    private string centersTitle  = "Là où j'ai enseigné.";
    private string centersIntro  = "Centres de formation et écoles qui m'ont confié leurs sessions, en présentiel comme en distanciel.";
    private string notFoundTitle = "Service introuvable.";
    private string notFoundLead = "Ce service n'existe pas dans ce slug. Retour à la liste des services.";
    private string backText = "Voir les services";
    private List<string>? seoStructuredData;

    protected override async Task LoadLocalizedStringsAsync()
    {
        await base.LoadLocalizedStringsAsync();
        await LoadServiceAsync();
        GenerateStructuredData();
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadServiceAsync();
        GenerateStructuredData();
    }

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        highlightsKicker = fr ? "Le périmètre" : "Scope";
        highlightsTitle  = fr ? "Ce que la mission couvre." : "What the engagement covers.";
        useCaseKicker    = fr ? "Cas d'usage" : "Use cases";
        useCaseTitle     = fr ? "Quand on m'appelle." : "When clients reach out.";
        faqKicker        = fr ? "Questions fréquentes" : "Frequent questions";
        faqTitle         = fr ? "Ce que les clients demandent." : "What clients ask.";
        catalogueKicker  = fr ? "Catalogue" : "Catalogue";
        catalogueTitle   = fr ? "20 modules pour vos équipes." : "20 modules for your teams.";
        centersKicker = fr ? "Partenaires"          : "Partners";
        centersTitle  = fr ? "Là où j'ai enseigné." : "Where I've taught.";
        centersIntro  = fr
            ? "Centres de formation et écoles qui m'ont confié leurs sessions, en présentiel comme en distanciel."
            : "Training centres and schools that have trusted me with their sessions, on-site and remote.";
        notFoundTitle    = fr ? "Service introuvable." : "Service not found.";
        notFoundLead     = fr ? "Ce service n'existe pas. Retour à la liste." : "That service doesn't exist. Back to the list.";
        backText         = fr ? "Voir les services" : "See all services";
    }

    private async Task LoadServiceAsync()
    {
        if (string.IsNullOrWhiteSpace(Slug)) { service = null; return; }
        string culture = CultureService.CurrentCulture.Name;
        IReadOnlyList<ServiceModel> all = await Content.GetServicesAsync(culture);
        service = all.FirstOrDefault(s => string.Equals(s.Slug, Slug, StringComparison.OrdinalIgnoreCase));
        if (service is not null)
        {
            bool fr = culture.StartsWith("fr");
            seoTitle = $"{service.Title}, IdeaStud.io";
            seoDescription = string.IsNullOrWhiteSpace(service.Tagline) ? service.Summary : service.Tagline;
            seoCanonical = $"https://ideastud.io{LocalizedRoute.For("services.hub", fr ? "fr" : "en")}/{service.Slug}";

            // Hreflang, service slugs differ per culture, so translate the slug.
            string cur = fr ? "fr" : "en";
            string other = fr ? "en" : "fr";
            string? otherSlug = await SlugTranslator.TranslateServiceSlugAsync(service.Slug, cur, other);
            if (otherSlug is not null)
            {
                string frSlug = fr ? service.Slug : otherSlug;
                string enSlug = fr ? otherSlug : service.Slug;
                string frUrl = $"https://ideastud.io{LocalizedRoute.For("services.hub", "fr")}/{frSlug}";
                string enUrl = $"https://ideastud.io{LocalizedRoute.For("services.hub", "en")}/{enSlug}";
                seoHreflang = new Dictionary<string, string>
                {
                    ["fr"] = frUrl,
                    ["en"] = enUrl,
                    ["x-default"] = frUrl,
                };
            }

            if (IsTrainerService(service))
            {
                trainings = await Content.GetTrainingsAsync(culture);
                centers   = await Content.GetTrainingCentersAsync(culture);
            }
        }
    }

    private void GenerateStructuredData()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        string cultureCode = fr ? "fr" : "en";

        List<string> blocks = new();

        SchemaOrg.Person person = new(
            Name: "Andrés Talavera",
            JobTitle: fr ? "Consultant .NET & Azure, Tech lead, Formateur" : ".NET & Azure Consultant, Tech Lead, Trainer",
            Description: seoDescription,
            Url: "https://ideastud.io",
            Image: "https://ideastud.io/images/andres-talavera.jpeg",
            SameAs: new[] { "https://www.linkedin.com/in/andrestalavera/", "https://github.com/andrestalavera" },
            KnowsAbout: new[] { ".NET", "Azure", "Blazor" },
            Address: null,
            WorksFor: new SchemaOrg.Organization(Name: "IdeaStud.io", Url: "https://ideastud.io")
        );

        if (service is not null)
        {
            SchemaOrg.Service svc = new(
                Name: service.Title,
                Description: string.IsNullOrWhiteSpace(service.Tagline) ? service.Summary : service.Tagline,
                Provider: person,
                AreaServed: fr ? "France · Suisse · Europe (remote)" : "France · Switzerland · Europe (remote)");
            blocks.Add(SchemaOrg.ToJsonLd(svc));

            if (service.Faq is { Count: > 0 })
            {
                SchemaOrg.FAQPage faq = new(
                    service.Faq.Select(f => new SchemaOrg.Question(f.Question, new SchemaOrg.Answer(f.Answer))).ToArray());
                blocks.Add(SchemaOrg.ToJsonLd(faq));
            }

            if (IsTrainerService(service) && trainings is { Count: > 0 })
            {
                foreach (Training t in trainings)
                {
                    SchemaOrg.Course course = new(
                        Name: t.Title,
                        Description: t.Summary,
                        Provider: person,
                        CourseCode: t.Slug,
                        EducationalLevel: t.Level,
                        TimeRequired: t.DurationDays is int d ? $"P{d}D" : null,
                        Url: $"https://ideastud.io{LocalizedRoute.For("services.hub", cultureCode)}/{service.Slug}#{t.Slug}");
                    blocks.Add(SchemaOrg.ToJsonLd(course));
                }
            }
        }

        blocks.Add(SchemaOrg.ToJsonLd(
            SchemaOrg.CreateBreadcrumb(
                "https://ideastud.io",
                (fr ? "Accueil" : "Home", LocalizedRoute.For("home", cultureCode)),
                (fr ? "Services" : "Services", LocalizedRoute.For("services.hub", cultureCode)),
                (service?.Title ?? Slug ?? "Service",
                    $"{LocalizedRoute.For("services.hub", cultureCode)}/{service?.Slug ?? Slug ?? string.Empty}")
            )));

        seoStructuredData = blocks;
    }

    private static bool IsTrainerService(ServiceModel? svc) =>
        svc is not null && (svc.Slug is "formateur" or "trainer");
}
