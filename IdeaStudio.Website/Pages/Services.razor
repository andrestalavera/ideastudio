@page "/fr/services"
@page "/en/services"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@using ServiceModel = IdeaStudio.Website.Models.Service
@inherits LocalizedComponent
@inject ILazyLoadingService LazyLoadingService
@inject ILocalizedRoute LocalizedRoute
@layout MainLayout

<PageScene Name="services-hub" />

<SeoHead Title="@seoTitle"
         Description="@seoDescription"
         Keywords=".NET, Azure, Techlead, Formateur, Consulting, Lyon"
         Author="Andrés Talavera"
         CanonicalUrl="@seoCanonical"
         Url="@seoCanonical"
         SiteName="IdeaStud.io"
         OgImage="https://ideastud.io/images/andres-talavera.jpeg"
         OgImageAlt="Andrés Talavera - Services"
         Locale="@seoLocale"
         HreflangUrls="@seoHreflangUrls"
         StructuredData="@seoStructuredData" />

<section class="ds-chapter" data-reveal style="--reveal-step: 1">
    <div class="ds-container">
        <header class="ds-chapter__heading">
            <p class="ds-chapter__kicker">@kickerText</p>
            <RevealWords Text="@hubTitle" Tag="h1" Class="ds-chapter__title" />
            <div class="ds-chapter__rule"></div>
            <p class="ds-body-lead">@hubLead</p>
        </header>

        <div class="ds-grid ds-grid--3">
            @foreach ((ServiceModel service, int idx) in services.OrderBy(s => s.Order).Select((s, i) => (s, i)))
            {
                <div data-reveal style="--reveal-step: @idx">
                    <ServiceCard Service="@service" />
                </div>
            }
        </div>
    </div>
</section>

<div data-reveal style="--reveal-step: 2">
    <CtaCalendlySection />
</div>

@code {
    private IReadOnlyList<ServiceModel> services = [];
    private string hubTitle = "My services";
    private string hubLead = "";
    private string kickerText = "· Services ·";
    private string seoTitle = "Services — IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/en/services";
    private string seoLocale = "en_US";
    private Dictionary<string, string> seoHreflangUrls = new();
    private List<string>? seoStructuredData;

    protected override async Task LoadLocalizedStringsAsync()
    {
        await base.LoadLocalizedStringsAsync();
        await LoadDataAsync();
        GenerateStructuredData();
        StateHasChanged();
    }

    protected override void LoadTexts()
    {
        hubTitle = LocalizationService.GetString("Services.HubTitle");
        hubLead = LocalizationService.GetString("Services.HubLead");

        bool isFr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = isFr ? "fr_FR" : "en_US";
        kickerText = isFr ? "· Services ·" : "· Services ·";
        seoTitle = isFr
            ? "Mes services — Consulting .NET & Azure, Tech lead, Formation | IdeaStud.io"
            : "My services — .NET & Azure consulting, Tech lead, Training | IdeaStud.io";
        seoDescription = isFr
            ? "Six façons de vous accompagner sur vos projets tech : consulting .NET & Azure, tech lead, formation, vibe coding, applications mobiles, sites web."
            : "Six ways I can help on your tech projects: .NET & Azure consulting, tech lead, training, vibe coding, mobile apps, websites.";
        seoCanonical = isFr ? "https://ideastud.io/fr/services" : "https://ideastud.io/en/services";
        seoHreflangUrls = new Dictionary<string, string>
        {
            ["fr"] = "https://ideastud.io/fr/services",
            ["en"] = "https://ideastud.io/en/services",
            ["x-default"] = "https://ideastud.io/en/services"
        };

        GenerateStructuredData();
    }

    private async Task LoadDataAsync()
    {
        string lang = CultureService.CurrentCulture.Name.StartsWith("fr") ? "fr" : "en";
        List<ServiceModel>? s = await LazyLoadingService.LoadDataAsync<List<ServiceModel>>($"data/services-{lang}.json");
        services = s ?? [];
    }

    private void GenerateStructuredData()
    {
        bool isFr = CultureService.CurrentCulture.Name.StartsWith("fr");
        string areaServed = isFr ? "France et international (remote)" : "France and worldwide (remote)";

        SchemaOrg.Person person = new(
            Name: "Andrés Talavera",
            JobTitle: isFr ? "Consultant .NET & Azure, Tech lead, Formateur" : ".NET & Azure Consultant, Tech Lead, Trainer",
            Description: seoDescription,
            Url: "https://ideastud.io",
            Image: "https://ideastud.io/images/andres-talavera.jpeg"
        );

        string cultureCode = isFr ? "fr" : "en";
        SchemaOrg.BreadcrumbList breadcrumb = SchemaOrg.CreateBreadcrumb(
            "https://ideastud.io",
            (isFr ? "Accueil" : "Home", LocalizedRoute.For("home", cultureCode)),
            (isFr ? "Services" : "Services", LocalizedRoute.For("services.hub", cultureCode)));

        List<SchemaOrg.Service> svcs = services
            .OrderBy(s => s.Order)
            .Select(s => new SchemaOrg.Service(
                Name: s.Title,
                Description: string.IsNullOrWhiteSpace(s.Tagline) ? s.Summary : s.Tagline,
                Provider: person,
                AreaServed: areaServed))
            .ToList();

        SchemaOrg.ProfessionalService professional = new(
            Name: isFr ? "Services IdeaStud.io" : "IdeaStud.io services",
            Description: seoDescription,
            Url: seoCanonical,
            AreaServed: areaServed,
            Provider: person,
            Services: svcs);

        seoStructuredData = new List<string>
        {
            SchemaOrg.ToJsonLd(breadcrumb),
            SchemaOrg.ToJsonLd(professional)
        };
    }
}
