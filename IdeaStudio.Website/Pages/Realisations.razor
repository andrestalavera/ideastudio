@page "/fr/realisations"
@page "/en/projects"
@page "/fr/portfolio"
@page "/en/portfolio"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription" CanonicalUrl="@seoCanonical" Locale="@seoLocale" />

<Hero Kicker="— Projets" Title="@titleText" Lead="@lead" />

@code {
    private string seoTitle = "Réalisations — IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/realisations";
    private string seoLocale = "fr_FR";
    private string titleText = "Réalisations récentes.";
    private string lead = "";

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        seoCanonical = fr ? "https://ideastud.io/fr/realisations" : "https://ideastud.io/en/projects";
        seoTitle = fr ? "Réalisations — IdeaStud.io" : "Projects — IdeaStud.io";
        titleText = fr ? "Réalisations récentes." : "Recent projects.";
        lead = fr
            ? "Une sélection de travaux récents — web, mobile, backend."
            : "A selection of recent work — web, mobile, backend.";
        seoDescription = lead;
    }
}
