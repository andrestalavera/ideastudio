@page "/fr/realisations"
@page "/en/projects"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@inject ILazyLoadingService LazyLoadingService
@layout MainLayout

<SeoHead Title="@seoTitle"
         Description="@seoDescription"
         Author="Andrés Talavera"
         CanonicalUrl="@seoCanonical"
         Url="@seoCanonical"
         SiteName="IdeaStud.io"
         OgImage="https://ideastud.io/images/andres-talavera.jpeg"
         OgImageAlt="@seoTitle"
         Locale="@seoLocale"
         HreflangUrls="@seoHreflangUrls" />

<section class="ds-chapter">
    <div class="ds-container">
        <header class="ds-chapter__heading">
            <p class="ds-chapter__kicker">@kickerText</p>
            <h1 class="ds-chapter__title">@titleText</h1>
            <div class="ds-chapter__rule"></div>
            <p class="ds-body-lead">@leadText</p>
        </header>

        @if (realisations.Count > 0)
        {
            <div class="ds-grid ds-grid--realisations">
                @foreach (Realisation r in OrderedRealisations)
                {
                    <RealisationCard Realisation="@r" />
                }
            </div>
        }
        else
        {
            <Placeholder />
        }
    </div>
</section>

<CtaCalendlySection />

@code {
    private IReadOnlyList<Realisation> realisations = [];
    private string titleText = "Recent projects";
    private string leadText = "";
    private string kickerText = "· Realisations ·";
    private string seoTitle = "Projects — IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/en/projects";
    private string seoLocale = "en_US";
    private Dictionary<string, string> seoHreflangUrls = new();

    private IEnumerable<Realisation> OrderedRealisations =>
        realisations.OrderBy(r => r.DisplayOrder).ThenByDescending(r => r.CompletedOn);

    protected override async Task LoadLocalizedStringsAsync()
    {
        await base.LoadLocalizedStringsAsync();
        await LoadDataAsync();
        StateHasChanged();
    }

    protected override void LoadTexts()
    {
        titleText = LocalizationService.GetString("Home.RealisationsTitle");
        leadText = LocalizationService.GetString("Home.RealisationsLead");

        bool isFr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = isFr ? "fr_FR" : "en_US";
        kickerText = isFr ? "· Réalisations ·" : "· Projects ·";
        seoTitle = isFr
            ? "Mes réalisations — Projets .NET, Azure, mobile et web | IdeaStud.io"
            : "My projects — .NET, Azure, mobile and web work | IdeaStud.io";
        seoDescription = isFr
            ? "Une sélection de projets récents : applications web et mobiles, plateformes .NET/Azure et sites vitrines."
            : "A selection of recent projects: web and mobile apps, .NET/Azure platforms and showcase websites.";
        seoCanonical = isFr ? "https://ideastud.io/fr/realisations" : "https://ideastud.io/en/projects";
        seoHreflangUrls = new Dictionary<string, string>
        {
            ["fr"] = "https://ideastud.io/fr/realisations",
            ["en"] = "https://ideastud.io/en/projects",
            ["x-default"] = "https://ideastud.io/en/projects"
        };
    }

    private async Task LoadDataAsync()
    {
        string lang = CultureService.CurrentCulture.Name.StartsWith("fr") ? "fr" : "en";
        List<Realisation>? r = await LazyLoadingService.LoadDataAsync<List<Realisation>>($"data/realisations-{lang}.json");
        realisations = r ?? [];
    }
}
