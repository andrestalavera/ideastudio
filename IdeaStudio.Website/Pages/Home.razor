@page "/fr"
@page "/en"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@using ServiceModel = IdeaStudio.Website.Models.Service
@inherits LocalizedComponent
@inject IContentGateway Content
@inject ILocalizedRoute LocalizedRoute
@layout MainLayout

<SeoHead Title="@seoTitle"
         Description="@seoDescription"
         Author="Andrés Talavera"
         CanonicalUrl="@seoCanonical"
         HreflangUrls="@LocalizedRoute.Alternates("home")"
         SiteName="IdeaStud.io"
         Locale="@seoLocale"
         OgImage="https://ideastud.io/images/andres-talavera.jpeg"
         OgImageAlt="Andrés Talavera - .NET & Azure"
         StructuredData="@seoStructuredData"
         SpeakableSelectors="@speakable" />

@* 1 · Hero — asymmetric editorial layout: name occupies the left ten columns
   at display scale, kicker pinned vertically to the right rail as an
   orientation marker, lead offset right beneath the name. Per-character
   reveal preserved; --hero-progress scroll morph preserved. *@
<div class="ds-page--home">
<section class="ds-hero ds-hero--home">
    <div class="ds-container ds-container--wide">
        <div class="ds-hero__inner">
            <div class="ds-hero__identity" data-reveal style="--reveal-step: 0">
                <img class="ds-hero__avatar" src="images/andres-talavera.jpeg"
                     alt="@avatarAlt" width="800" height="800" fetchpriority="high" decoding="async" />
                <p class="ds-kicker ds-hero__kicker">@kicker</p>
            </div>
            <RevealChars Text="Andrés Talavera" Tag="h1" Class="ds-display ds-hero__name">
                <span class="ds-display__accent" aria-hidden="true">.</span>
            </RevealChars>
            <p class="ds-lead ds-hero__lead" data-reveal style="--reveal-step: 2">@lead</p>
            <div class="ds-hero__actions" data-reveal style="--reveal-step: 3">
                <ActionRow Label="@meetLabel" DownloadUrl="@downloadUrl" DownloadLabel="@downloadLabel" />
            </div>
        </div>
    </div>
</section>

@* 2 · Why work with me — concrete, benefit-led value props *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@benefitsKicker" Title="@benefitsTitle" Lead="@benefitsLead" />
        <div class="ds-grid ds-grid--2 ds-chapter-gap">
            @for (int i = 0; i < benefits.Count; i++)
            {
                (string t, string b) = benefits[i];
                <div class="ds-card" data-reveal style="@($"--reveal-step:{i}")">
                    <h3 class="ds-card__title">@t</h3>
                    <p class="ds-card__body">@b</p>
                </div>
            }
        </div>
    </div>
</section>

@* 2b · Trusted by — client logo strip (social proof) *@
@if (clients.Count > 0)
{
    <section class="ds-section ds-section--bordered">
        <div class="ds-container">
            <p class="ds-kicker" data-reveal style="margin-block-end: 1.5rem;">@clientsKicker</p>
            <LogoWall Items="@clients" />
        </div>
    </section>
}

@* 3 · Latest realisations — editorial zig-zag stack, not uniform rows *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@realisationsKicker" Title="@realisationsTitle" />
        <div class="ds-home__projects ds-chapter-gap">
            @if (realisations.Count > 0)
            {
                foreach (Realisation r in realisations.Take(3))
                {
                    bool hasCase = r.CaseStudy is not null;
                    string href = hasCase ? $"{LocalizedRoute.For("realisations")}/{r.Slug}" : r.LiveUrl;
                    <ProjectTile Href="@href"
                                 Target="@(hasCase ? null : "_blank")" Rel="@(hasCase ? null : "noopener")"
                                 Badge="@(hasCase ? caseBadge : null)"
                                 ImageUrl="@r.ImageUrl" ImageAlt="@r.ImageAlt"
                                 Type="@r.Type.ToString()" Year="@r.CompletedOn.Year.ToString()"
                                 Title="@r.Title" Summary="@r.Summary"
                                 Tags="@r.Technologies" />
                }
            }
        </div>
        <p class="ds-chapter-gap" data-reveal>
            <a class="ds-link" href="@LocalizedRoute.For("realisations")">
                @seeAllRealisations <span class="ds-link__arrow" aria-hidden="true">→</span>
            </a>
        </p>
    </div>
</section>

@* 4 · Go to my resume *@
<ResumeBand YearsValue="@yearsValue"
            StackValue=".NET · Azure · Mobile"
            LanguagesValue="FR · EN · ES" />

@* 5 · About teaser — who's behind the work *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@aboutKicker" Title="@aboutTitle" Lead="@aboutLead" />
        <p class="ds-chapter-gap" data-reveal>
            <a class="ds-link" href="@LocalizedRoute.For("about")">
                @aboutCta <span class="ds-link__arrow" aria-hidden="true">→</span>
            </a>
        </p>
    </div>
</section>

@* 6 · Services *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@servicesKicker" Title="@servicesTitle" />
        <div class="ds-chapter-gap" data-reveal>
            <EditorialList Items="@services" />
        </div>
        <p class="ds-chapter-gap" data-reveal>
            <a class="ds-link" href="@LocalizedRoute.For("services.hub")">
                @seeAllServices <span class="ds-link__arrow" aria-hidden="true">→</span>
            </a>
        </p>
    </div>
</section>

@* 7 · Where I teach *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@teachKicker" Title="@teachTitle" />
        <div class="ds-chapter-gap">
            <TeachList Centers="@trainingCenters" />
        </div>
        <p class="ds-chapter-gap" data-reveal>
            <a class="ds-link" href="@($"{LocalizedRoute.For("services.hub")}/{trainerSlug}")">
                @allTrainings <span class="ds-link__arrow" aria-hidden="true">→</span>
            </a>
        </p>
    </div>
</section>

@* 8 · Questions (expanded Q&A — magazine-style 2-col Q/A layout on desktop) *@
<section class="ds-section ds-section--chapter ds-section--bordered">
    <div class="ds-container">
        <ChapterBand Kicker="@questionsKicker" Title="@questionsTitle" />
        <div class="ds-chapter-gap ds-faq-list">
            @for (int i = 0; i < faq.Count; i++)
            {
                (string q, string a) = faq[i];
                <QABlock Kicker="@($"Q {i + 1:D2}")" Question="@q" Answer="@a" Step="@i" />
            }
        </div>
        <p class="ds-chapter-gap" data-reveal>
            <a class="ds-link" href="@LocalizedRoute.For("faq")">
                @seeAllFaq <span class="ds-link__arrow" aria-hidden="true">→</span>
            </a>
        </p>
    </div>
</section>
</div>

@code {
    private IReadOnlyList<ServiceModel> services = Array.Empty<ServiceModel>();
    private IReadOnlyList<Realisation> realisations = Array.Empty<Realisation>();
    private IEnumerable<TrainingCenter>? trainingCenters;
    private List<(string Q, string A)> faq = new();

    private string kicker = "CONSULTANT · TECHLEAD · FORMATEUR";
    private string lead = "Je transforme des idées en logiciels qui marchent.";
    private string avatarAlt = "Andrés Talavera, consultant et développeur .NET & Azure";
    private string meetLabel = "Rencontrer";
    private string downloadLabel = "Télécharger CV";
    private string downloadUrl = "cv.pdf";
    private List<(string Title, string Body)> benefits = new();
    private List<LogoWall.LogoItem> clients = new();
    private string clientsKicker = "Ils m'ont fait confiance";
    private string benefitsKicker = "Pourquoi moi";
    private string benefitsTitle = "Ce que vous y gagnez.";
    private string benefitsLead = "";
    private string realisationsKicker = "Réalisations";
    private string realisationsTitle = "Projets récents.";
    private string seeAllRealisations = "Voir toutes les réalisations";
    private string caseBadge = "Étude de cas";
    private string aboutKicker = "À propos";
    private string aboutTitle = "Qui se cache derrière le code.";
    private string aboutLead = "";
    private string aboutCta = "En savoir plus sur moi";
    private string servicesKicker = "Services";
    private string servicesTitle = "Sept façons de collaborer.";
    private string seeAllServices = "Voir tous les services";
    private string teachKicker = "Formations";
    private string teachTitle = "Où j'enseigne.";
    private string allTrainings = "Voir toutes les formations";
    private string trainerSlug = "formateur";
    private string questionsKicker = "Questions";
    private string questionsTitle = "Les plus demandées.";
    private string seeAllFaq = "Voir toutes les questions";
    private string yearsValue = "15";

    private string seoTitle = "IdeaStud.io — Andrés Talavera";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr";
    private string seoLocale = "fr_FR";
    private List<string>? seoStructuredData;
    private List<string> speakable = new() { ".ds-hero .ds-lead", ".ds-hero .ds-display" };

    protected override async Task LoadLocalizedStringsAsync()
    {
        await base.LoadLocalizedStringsAsync();
        await LoadDataAsync();
        GenerateStructuredData();
        StateHasChanged();
    }

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        seoCanonical = fr ? "https://ideastud.io/fr" : "https://ideastud.io/en";
        seoTitle = fr
            ? "Andrés Talavera — Consultant .NET & Azure, Techlead, Formateur | IdeaStud.io"
            : "Andrés Talavera — .NET & Azure Consultant, Tech Lead, Trainer | IdeaStud.io";
        lead = fr
            ? "Je vous aide à transformer une idée en logiciel que vos clients utilisent vraiment — et sur lequel votre équipe peut continuer à bâtir. Autour de Lyon, Paris, Genève et Fribourg, ou en full-remote."
            : "I help you turn an idea into software your customers actually use — and your team can keep building on. Around Lyon, Paris, Geneva and Fribourg, or fully remote.";
        // SEO description stays keyword-rich even though the visible lead is warmer.
        seoDescription = fr
            ? "Andrés Talavera — consultant .NET & Azure, techlead et formateur. Je transforme vos idées en logiciels fiables (web, mobile, cloud). Lyon · Paris · Genève · Fribourg ou à distance."
            : "Andrés Talavera — .NET & Azure consultant, tech lead and trainer. I turn your ideas into reliable software (web, mobile, cloud). Lyon · Paris · Geneva · Fribourg or remote.";
        avatarAlt = fr
            ? "Andrés Talavera, consultant et développeur .NET & Azure"
            : "Andrés Talavera, .NET & Azure consultant and developer";

        kicker = fr
            ? "CONSULTANT · TECHLEAD · FORMATEUR"
            : "CONSULTANT · TECH LEAD · TRAINER";

        meetLabel = fr ? "Rencontrer" : "Meet";
        downloadLabel = fr ? "Télécharger CV" : "Download resume";
        downloadUrl = fr ? "cv.pdf?culture=fr" : "resume.pdf?culture=en";

        clientsKicker  = fr ? "Ils m'ont fait confiance" : "Trusted by";
        benefitsKicker = fr ? "Pourquoi moi" : "Why me";
        benefitsTitle  = fr ? "Ce que vous y gagnez." : "What you get.";
        benefitsLead   = fr
            ? "Un interlocuteur unique, senior et impliqué — pas un intermédiaire. Voici concrètement ce que ça change pour vous."
            : "One senior, hands-on point of contact — not a middleman. Here's concretely what that changes for you.";
        benefits = fr
            ? new() {
                ("Senior et impliqué", "15+ ans à concevoir du logiciel .NET/Azure. Vous avez un architecte qui code encore et porte le résultat — pas un slide deck."),
                ("Livrer vite, sans dette cachée", "Développement assisté par IA (Claude Code, Copilot), chaque ligne générée relue. De la vitesse qui ne se retourne pas contre vous."),
                ("Des tarifs clairs, sans surprise", "TJM à partir de 600 €, premier échange de 30 min offert, devis sous 24 h. Vous savez toujours ce que vous payez."),
                ("Près de vous, ou à distance", "Sur site à Lyon, Paris, Genève et Fribourg, ou full-remote. Facturation simple via portage (EUR, ou CHF côté suisse).")
            }
            : new() {
                ("Senior and hands-on", "15+ years building .NET/Azure software. You get an architect who still writes code and owns the outcome — not a slide deck."),
                ("Ship faster, no hidden debt", "AI-assisted delivery (Claude Code, Copilot), every generated line reviewed. Speed that doesn't come back to bite you."),
                ("Clear pricing, no surprises", "Day rate from 600 €, free 30-minute scoping call, quote within 24h. You always know what you're paying for."),
                ("Where you are, or remote", "On-site in Lyon, Paris, Geneva and Fribourg, or fully remote. Simple invoicing via wage-portage (EUR, or CHF for Swiss work).")
            };

        realisationsKicker = fr ? "Réalisations" : "Work";
        realisationsTitle  = fr ? "Projets récents." : "Recent projects.";
        seeAllRealisations = fr ? "Voir toutes les réalisations" : "See all projects";
        caseBadge          = fr ? "Étude de cas" : "Case study";

        aboutKicker = fr ? "À propos" : "About";
        aboutTitle  = fr ? "Qui se cache derrière le code." : "The person behind the code.";
        aboutLead   = fr
            ? "Consultant, techlead et formateur indépendant. Un même fil rouge depuis 15 ans : transformer des idées en logiciels qui marchent."
            : "Independent consultant, tech lead and trainer. One thread for 15 years: turning ideas into software that ships.";
        aboutCta    = fr ? "En savoir plus sur moi" : "More about me";

        servicesKicker = fr ? "Services" : "Services";
        servicesTitle  = fr ? "Sept façons de collaborer." : "Seven ways to collaborate.";
        seeAllServices = fr ? "Voir tous les services" : "See all services";

        teachKicker = fr ? "Formations" : "Trainings";
        teachTitle  = fr ? "Où j'enseigne." : "Where I teach.";
        allTrainings = fr ? "Voir toutes les formations" : "See all trainings";
        trainerSlug = fr ? "formateur" : "trainer";

        questionsKicker = fr ? "Questions" : "Questions";
        questionsTitle  = fr ? "Les plus demandées." : "Most asked.";
        seeAllFaq       = fr ? "Voir toutes les questions" : "See all questions";

        faq = fr
            ? new() {
                ("Quels projets acceptez-vous ?", "Conseil, techlead, formation, accompagnement IA, ou réalisations sur-mesure — .NET, Azure, mobile, web. Si le cadrage est clair et le délai sain, j'y vais."),
                ("Quels sont vos tarifs ?", "TJM à partir de 600 € (conseil, techlead) et 800 € (formation, IA). Ajusté selon durée et implication. Premier échange de 30 min offert, devis sous 24 h."),
                ("Où pouvez-vous intervenir ?", "Lyon, Paris, Genève, Fribourg — sur site, hybride ou full-remote selon votre besoin. Je me déplace pour les kick-offs, les ateliers et les formations."),
                ("Comment travaille-t-on ensemble ?", "En portage salarial via OpenWork (société française) : un cadre contractuel simple pour vous comme pour moi. Facturation en EUR par défaut, CHF possible côté suisse."),
                ("Quelles formations dispensez-vous ?", "Vingt modules au catalogue : .NET, Azure, IA & vibe coding, architecture & DevOps. En inter ou en intra sur-mesure. Formateur certifié Microsoft (MCT)."),
                ("Comment garantissez-vous la qualité avec l'IA ?", "Aucune ligne générée n'est livrée sans relecture. Je raisonne, je vérifie, je corrige — la vitesse de l'IA n'a de valeur que si elle ne crée pas de dette cachée.")
            }
            : new() {
                ("What projects do you take on?", "Consulting, tech-lead, training, AI enablement, or custom delivery — .NET, Azure, mobile, web. If the scope is clear and the timeline sane, I'm in."),
                ("What are your rates?", "Day rate from 600 € (consulting, tech-lead) and 800 € (training, AI). Adjusted for duration and involvement. First 30-minute call is free, quote within 24h."),
                ("Where do you work?", "Lyon, Paris, Geneva, Fribourg — on-site, hybrid or fully remote depending on your need. I travel for kick-offs, workshops and training."),
                ("How do we work together?", "Via French wage-portage company OpenWork: a simple contractual frame for both sides. Default invoicing in EUR, CHF available for Swiss work."),
                ("What trainings do you deliver?", "Twenty catalogue modules: .NET, Azure, AI & vibe coding, architecture & DevOps. Inter-company or bespoke in-house. Microsoft Certified Trainer (MCT)."),
                ("How do you keep quality with AI?", "No generated line ships without review. I reason, verify, correct — AI speed is only valuable if it doesn't create hidden debt.")
            };
    }

    private async Task LoadDataAsync()
    {
        string culture = CultureService.CurrentCulture.Name;
        services     = await Content.GetServicesAsync(culture);
        realisations = await Content.GetRealisationsAsync(culture);
        clients = realisations
            .Where(r => !string.IsNullOrWhiteSpace(r.LiveUrl))
            .Select(r => new LogoWall.LogoItem(r.Client, LogoUrl: null, Url: r.LiveUrl))
            .ToList();
        Resume? resume = await Content.GetResumeAsync(culture);
        IReadOnlyList<TrainingCenter> centers = await Content.GetTrainingCentersAsync(culture);
        trainingCenters = centers.Take(6).ToArray();

        if (resume is not null && resume.Experiences is { Count: > 0 })
        {
            DateTime earliest = resume.Experiences.Min(e => e.StartDate);
            int years = Math.Max(1, DateTime.Today.Year - earliest.Year);
            yearsValue = years.ToString();
        }
    }

    private void GenerateStructuredData()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        string cultureCode = fr ? "fr" : "en";
        string servicesUrl = $"https://ideastud.io{LocalizedRoute.For("services.hub", cultureCode)}";

        SchemaOrg.Person person = new(
            Name: "Andrés Talavera",
            JobTitle: fr ? "Consultant .NET & Azure, Tech lead, Formateur" : ".NET & Azure Consultant, Tech Lead, Trainer",
            Description: seoDescription,
            Url: "https://ideastud.io",
            Image: "https://ideastud.io/images/andres-talavera.jpeg",
            SameAs: new[] { "https://www.linkedin.com/in/andrestalavera/", "https://github.com/andrestalavera" },
            KnowsAbout: new[] { ".NET", "Azure", "Blazor", "ASP.NET Core", "Cloud Architecture", "Software Training" },
            Address: new SchemaOrg.PostalAddress(AddressLocality: "Lyon", AddressRegion: "Auvergne-Rhône-Alpes", AddressCountry: "FR"),
            WorksFor: new SchemaOrg.Organization(Name: "IdeaStud.io", Url: "https://ideastud.io"),
            WorkLocation: new[]
            {
                new SchemaOrg.Place(new SchemaOrg.PostalAddress(AddressLocality: "Lyon", AddressCountry: "FR")),
                new SchemaOrg.Place(new SchemaOrg.PostalAddress(AddressLocality: "Paris", AddressCountry: "FR")),
                new SchemaOrg.Place(new SchemaOrg.PostalAddress(AddressLocality: fr ? "Genève" : "Geneva", AddressCountry: "CH")),
                new SchemaOrg.Place(new SchemaOrg.PostalAddress(AddressLocality: "Fribourg", AddressCountry: "CH"))
            },
            KnowsLanguage: new[] { "fr", "en", "es" }
        );

        SchemaOrg.WebSite website = new(
            Name: "IdeaStud.io",
            Url: "https://ideastud.io",
            Description: fr
                ? "Portfolio et services d'Andrés Talavera, consultant .NET & Azure à Lyon."
                : "Portfolio and services of Andrés Talavera, .NET & Azure consultant in Lyon."
        );

        SchemaOrg.BreadcrumbList breadcrumb = SchemaOrg.CreateBreadcrumb(
            "https://ideastud.io",
            (fr ? "Accueil" : "Home", LocalizedRoute.For("home", cultureCode)));

        List<SchemaOrg.Service> svcs = services
            .Select(s => new SchemaOrg.Service(
                Name: s.Title,
                Description: string.IsNullOrWhiteSpace(s.Tagline) ? s.Summary : s.Tagline,
                Provider: person,
                AreaServed: fr ? "France · Suisse · Europe (remote)" : "France · Switzerland · Europe (remote)"))
            .ToList();

        SchemaOrg.ProfessionalService professional = new(
            Name: fr ? "Services IdeaStud.io" : "IdeaStud.io services",
            Description: seoDescription,
            Url: servicesUrl,
            AreaServed: fr ? "France · Suisse · Europe (remote)" : "France · Switzerland · Europe (remote)",
            Provider: person,
            Services: svcs,
            PriceRange: fr ? "TJM 600–800 €" : "Day rate €600–800",
            AvailableLanguage: new[] { "fr", "en", "es" });

        // FAQPage JSON-LD — fed by the 3 Home Q&A.
        SchemaOrg.FAQPage faqPage = new(
            faq.Select(x => new SchemaOrg.Question(x.Q, new SchemaOrg.Answer(x.A))).ToArray()
        );

        seoStructuredData = new List<string>
        {
            SchemaOrg.ToJsonLd(person),
            SchemaOrg.ToJsonLd(website),
            SchemaOrg.ToJsonLd(breadcrumb),
            SchemaOrg.ToJsonLd(professional),
            SchemaOrg.ToJsonLd(faqPage)
        };
    }
}
