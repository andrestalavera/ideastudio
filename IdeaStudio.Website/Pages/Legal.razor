@page "/fr/mentions-legales"
@page "/en/legal"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription" CanonicalUrl="@seoCanonical" Locale="@seoLocale" />

<Hero Kicker="@kicker" Title="@titleText" />

<section class="ds-section">
    <div class="ds-container ds-container--narrow">
        <p class="ds-body">@leadText</p>
    </div>
</section>

@code {
    private string seoTitle = "Mentions légales";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/mentions-legales";
    private string seoLocale = "fr_FR";
    private string kicker = "— Légal";
    private string titleText = "Mentions légales.";
    private string leadText = "";

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        seoCanonical = fr ? "https://ideastud.io/fr/mentions-legales" : "https://ideastud.io/en/legal";
        seoTitle = fr ? "Mentions légales — IdeaStud.io" : "Legal notice — IdeaStud.io";
        kicker = fr ? "— Légal" : "— Legal";
        titleText = fr ? "Mentions légales." : "Legal notice.";
        leadText = fr
            ? "Page en cours de rédaction — V3 phase 2."
            : "Page under construction — V3 phase 2.";
        seoDescription = leadText;
    }
}
