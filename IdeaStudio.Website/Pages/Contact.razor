@page "/fr/contact"
@page "/en/contact"
@using IdeaStudio.Website.Components
@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@inherits LocalizedComponent
@inject IContactService ContactService
@inject IAnalyticsService Analytics
@inject ILocalizedRoute LocalizedRoute
@layout MainLayout

<SeoHead Title="@seoTitle" Description="@seoDescription"
         Author="Andrés Talavera"
         CanonicalUrl="@seoCanonical" Locale="@seoLocale"
         HreflangUrls="@LocalizedRoute.Alternates("contact")"
         SiteName="IdeaStud.io"
         OgImage="https://ideastud.io/images/andres-talavera.jpeg" OgImageAlt="Andrés Talavera"
         StructuredData="@seoStructuredData"
         SpeakableSelectors="@speakable" />

<Hero Kicker="@heroKicker" Title="@heroTitle" Lead="@heroLead" />

<PageSection Width="narrow">
    @if (status == Status.Success)
    {
        <div class="ds-form-status ds-form-status-ok" role="alert" data-reveal>
            <p class="ds-form-status-title">@successTitle</p>
            <p>@successBody</p>
        </div>
    }
    else
    {
        @if (status == Status.Error)
        {
            <div class="ds-form-status ds-form-status-err" role="alert">
                <p>@errorBody</p>
            </div>
        }

        @if (errors.Count > 0)
        {
            @* No data-reveal: the error summary must be visible the instant it renders
               (WCAG 4.1.3) — gating it behind the IntersectionObserver could flash blank. *@
            <div class="ds-form-status ds-form-status-err" role="alert" aria-live="assertive">
                <p class="ds-form-status-title">@errorSummaryTitle</p>
                <ul class="ds-form-error-summary">
                    @foreach (string field in OrderedErrorFields())
                    {
                        <li>@errors[field]</li>
                    }
                </ul>
            </div>
        }

        <p class="text-muted mb-6">@referralNote</p>

        <form class="ds-form" @onsubmit="HandleSubmit" @onsubmit:preventDefault novalidate>
            <div class="ds-field">
                <label class="ds-field-label" for="cf-name">@nameLabel</label>
                <input class="ds-field-input" id="cf-name" type="text" autocomplete="name"
                       @ref="nameInput"
                       @bind="model.Name" @bind:event="oninput"
                       aria-invalid="@Invalid(nameof(model.Name))"
                       aria-describedby="@(HasError(nameof(model.Name)) ? "cf-name-err" : null)" />
                @if (HasError(nameof(model.Name)))
                {
                    <span class="ds-field-error" id="cf-name-err">@errors[nameof(model.Name)]</span>
                }
            </div>

            <div class="ds-field">
                <label class="ds-field-label" for="cf-email">@emailLabel</label>
                <input class="ds-field-input" id="cf-email" type="email" autocomplete="email"
                       @ref="emailInput"
                       @bind="model.Email" @bind:event="oninput"
                       aria-invalid="@Invalid(nameof(model.Email))"
                       aria-describedby="@(HasError(nameof(model.Email)) ? "cf-email-err" : null)" />
                @if (HasError(nameof(model.Email)))
                {
                    <span class="ds-field-error" id="cf-email-err">@errors[nameof(model.Email)]</span>
                }
            </div>

            <div class="ds-field">
                <label class="ds-field-label" for="cf-subject">@subjectLabel <span class="ds-field-optional">@optionalLabel</span></label>
                <input class="ds-field-input" id="cf-subject" type="text"
                       @bind="model.Subject" @bind:event="oninput" />
            </div>

            <div class="ds-field">
                <label class="ds-field-label" for="cf-message">@messageLabel</label>
                <textarea class="ds-field-input ds-field-textarea" id="cf-message" rows="6"
                          @ref="messageInput"
                          @bind="model.Message" @bind:event="oninput"
                          aria-invalid="@Invalid(nameof(model.Message))"
                          aria-describedby="@(HasError(nameof(model.Message)) ? "cf-message-err" : null)"></textarea>
                @if (HasError(nameof(model.Message)))
                {
                    <span class="ds-field-error" id="cf-message-err">@errors[nameof(model.Message)]</span>
                }
            </div>

            <div class="ds-field ds-field-check">
                <label class="ds-field-check">
                    <input type="checkbox" @ref="consentInput" @bind="model.Consent"
                           aria-invalid="@Invalid(nameof(model.Consent))"
                           aria-describedby="@(HasError(nameof(model.Consent)) ? "cf-consent-err" : null)" />
                    <span>@consentLabel <a class="ds-link" href="@LocalizedRoute.For("privacy")">@privacyLinkLabel</a>.</span>
                </label>
                @if (HasError(nameof(model.Consent)))
                {
                    <span class="ds-field-error" id="cf-consent-err">@errors[nameof(model.Consent)]</span>
                }
            </div>

            @* Honeypot, hidden from humans, tempting to bots. *@
            <div class="ds-field ds-hp" aria-hidden="true">
                <label for="cf-website">Website</label>
                <input id="cf-website" type="text" tabindex="-1" autocomplete="off" @bind="model.Website" @bind:event="oninput" />
            </div>

            <div class="ds-form-actions">
                <button class="ds-btn ds-btn-primary" type="submit" disabled="@(status == Status.Sending)">
                    @(status == Status.Sending ? sendingLabel : submitLabel)
                    <span aria-hidden="true">→</span>
                </button>
                <ButtonLink Href="https://calendly.com/andres-talavera/30min" External="true" Label="@bookLabel" />
            </div>
        </form>

        <div class="mt-8" data-reveal>
            <p class="text-muted mb-3">@socialPrompt</p>
            <SocialLinks />
        </div>
    }
</PageSection>

@code {
    private enum Status { Idle, Sending, Success, Error }

    private readonly ContactFormModel model = new();
    private readonly Dictionary<string, string> errors = new();
    private Status status = Status.Idle;

    // Field order for the error summary + first-invalid focus on failed submit.
    private static readonly string[] FieldOrder =
        { nameof(ContactFormModel.Name), nameof(ContactFormModel.Email), nameof(ContactFormModel.Message), nameof(ContactFormModel.Consent) };

    private ElementReference nameInput;
    private ElementReference emailInput;
    private ElementReference messageInput;
    private ElementReference consentInput;
    private string? focusFieldOnRender;

    private string seoTitle = "Contact, IdeaStud.io";
    private string seoDescription = "";
    private string seoCanonical = "https://ideastud.io/fr/contact";
    private string seoLocale = "fr_FR";
    private string heroKicker = "Contact";
    private string heroTitle = "Parlons de votre projet.";
    private string heroLead = "";
    private string referralNote = "La plupart de mes missions viennent par recommandation. Présentations bienvenues.";
    private string nameLabel = "Nom";
    private string emailLabel = "Email";
    private string subjectLabel = "Sujet";
    private string optionalLabel = "(facultatif)";
    private string messageLabel = "Message";
    private string consentLabel = "J'accepte que mes données soient utilisées pour me recontacter, conformément à la";
    private string privacyLinkLabel = "politique de confidentialité";
    private string submitLabel = "Envoyer le message";
    private string sendingLabel = "Envoi…";
    private string bookLabel = "Ou réserver un appel";
    private string successTitle = "Message envoyé.";
    private string successBody = "Merci, je vous réponds en général sous 24 h ouvrées.";
    private string errorBody = "L'envoi a échoué. Réessayez, ou écrivez-moi directement à andres.talavera@ideastud.io.";
    private string errRequired = "Ce champ est requis.";
    private string errEmail = "Adresse email invalide.";
    private string errMessage = "Quelques mots de plus, s'il vous plaît (10 caractères minimum).";
    private string errConsent = "Merci de cocher cette case pour continuer.";
    private string errorSummaryTitle = "Veuillez corriger les erreurs suivantes :";
    private string socialPrompt = "Ou retrouvez-moi sur";
    private List<string>? seoStructuredData;
    private List<string> speakable = new() { ".ds-hero .ds-display", ".ds-hero .ds-lead" };

    private bool HasError(string field) => errors.ContainsKey(field);
    private string? Invalid(string field) => errors.ContainsKey(field) ? "true" : null;

    private IEnumerable<string> OrderedErrorFields() => FieldOrder.Where(errors.ContainsKey);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusFieldOnRender is null) return;

        string field = focusFieldOnRender;
        focusFieldOnRender = null;
        ElementReference target = field switch
        {
            nameof(ContactFormModel.Name) => nameInput,
            nameof(ContactFormModel.Email) => emailInput,
            nameof(ContactFormModel.Message) => messageInput,
            _ => consentInput
        };
        await target.FocusAsync();
    }

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        seoLocale = fr ? "fr_FR" : "en_US";
        seoCanonical = fr ? "https://ideastud.io/fr/contact" : "https://ideastud.io/en/contact";
        seoTitle = "Contact, Andrés Talavera | IdeaStud.io";
        heroTitle = fr ? "Parlons de votre projet." : "Let's talk about your project.";
        heroLead = fr
            ? "Décrivez votre besoin en quelques lignes. Je reviens vers vous sous 24 h ouvrées avec une proposition claire ou les bonnes questions. Sans engagement."
            : "Tell me about your need in a few lines. I'll get back to you within one business day with a clear proposal or the right questions. No strings attached.";
        seoDescription = heroLead;

        referralNote = fr
            ? "La plupart de mes missions viennent par recommandation. Présentations bienvenues."
            : "Most of my work comes by referral. Introductions welcome.";

        nameLabel = fr ? "Nom" : "Name";
        emailLabel = "Email";
        subjectLabel = fr ? "Sujet" : "Subject";
        optionalLabel = fr ? "(facultatif)" : "(optional)";
        messageLabel = "Message";
        consentLabel = fr
            ? "J'accepte que mes données soient utilisées pour me recontacter, conformément à la"
            : "I agree that my data may be used to get back to me, per the";
        privacyLinkLabel = fr ? "politique de confidentialité" : "privacy policy";
        submitLabel = fr ? "Envoyer le message" : "Send message";
        sendingLabel = fr ? "Envoi…" : "Sending…";
        bookLabel = fr ? "Ou réserver un appel" : "Or book a call";
        successTitle = fr ? "Message envoyé." : "Message sent.";
        successBody = fr
            ? "Merci, je vous réponds en général sous 24 h ouvrées."
            : "Thanks, I usually reply within one business day.";
        errorBody = fr
            ? "L'envoi a échoué. Réessayez, ou écrivez-moi directement à andres.talavera@ideastud.io."
            : "Sending failed. Please try again, or email me directly at andres.talavera@ideastud.io.";
        errRequired = fr ? "Ce champ est requis." : "This field is required.";
        errEmail = fr ? "Adresse email invalide." : "Invalid email address.";
        errMessage = fr ? "Quelques mots de plus, s'il vous plaît (10 caractères minimum)." : "A few more words, please (10 characters minimum).";
        errConsent = fr ? "Merci de cocher cette case pour continuer." : "Please tick this box to continue.";
        errorSummaryTitle = fr ? "Veuillez corriger les erreurs suivantes :" : "Please fix the following errors:";
        socialPrompt = fr ? "Ou retrouvez-moi sur" : "Or find me on";

        GenerateStructuredData();
    }

    private bool Validate()
    {
        errors.Clear();
        foreach (KeyValuePair<string, string> error in
            model.Validate(new ContactErrorMessages(errRequired, errEmail, errMessage, errConsent)))
        {
            errors[error.Key] = error.Value;
        }
        return errors.Count == 0;
    }

    private async Task HandleSubmit()
    {
        status = Status.Idle;

        // Honeypot tripped, silently accept without sending.
        if (model.IsSpam)
        {
            status = Status.Success;
            return;
        }

        if (!Validate())
        {
            // Move focus to the first invalid field; the aria-live summary
            // announces the full list to assistive tech.
            focusFieldOnRender = FieldOrder.FirstOrDefault(errors.ContainsKey);
            return;
        }

        status = Status.Sending;
        bool ok = await ContactService.SendAsync(
            new ContactRequest(model.Name.Trim(), model.Email.Trim(), model.Subject?.Trim(), model.Message.Trim()));
        status = ok ? Status.Success : Status.Error;
        if (ok)
        {
            await Analytics.TrackEventAsync("contact_submit");
        }
    }

    private void GenerateStructuredData()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        string cultureCode = fr ? "fr" : "en";

        SchemaOrg.BreadcrumbList breadcrumb = SchemaOrg.CreateBreadcrumb(
            "https://ideastud.io",
            (fr ? "Accueil" : "Home", LocalizedRoute.For("home", cultureCode)),
            ("Contact", LocalizedRoute.For("contact", cultureCode)));

        seoStructuredData = new List<string> { SchemaOrg.ToJsonLd(breadcrumb) };
    }
}
