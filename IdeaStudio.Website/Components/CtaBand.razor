@using IdeaStudio.Website.Services
@inherits LocalizedComponent

@* CtaBand, "Travaillons ensemble" band with iridescent Calendly pill.
   Shown on every page except Legal/Privacy. *@

<PageSection Rhythm="section" Class="ds-print-hidden">
    <div class="ds-rhythm" data-reveal>
        <p class="ds-kicker">@kickerText</p>
        <h2 class="ds-title">@titleText</h2>
        <p class="ds-lead">@leadText</p>
        <div class="mt-8">
            <ButtonLink Href="https://calendly.com/andres-talavera/30min" Variant="primary" External="true" Arrow="→" Label="@ctaText" />
        </div>
    </div>
</PageSection>

@code {
    private string kickerText = "Ensemble";
    private string titleText = "Travaillons ensemble.";
    private string leadText = "Un projet, une idée, un coup de main ? Parlons-en.";
    private string ctaText = "Prendre rendez-vous";

    protected override void LoadTexts()
    {
        bool fr = CultureService.CurrentCulture.Name.StartsWith("fr");
        kickerText = fr ? "Ensemble" : "Together";
        titleText  = fr ? "Travaillons ensemble." : "Let's work together.";
        leadText   = fr
            ? "Un projet, une idée, un coup de main ? Parlons-en."
            : "A project, an idea, a second pair of eyes? Let's talk.";
        ctaText    = fr ? "Prendre rendez-vous" : "Book a call";
    }
}
