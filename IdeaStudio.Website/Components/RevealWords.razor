@* Per-word reveal wrapper: splits Text into <span>s with a --i index used
   by SCSS to stagger animation-delay. Whitespace between words is kept as
   plain text so the browser can wrap naturally. The host element carries
   aria-label=Text and each word span is aria-hidden so assistive tech reads
   the string once, not word by word. The bigger-drama sibling of
   <RevealText />, meant for chapter titles. *@

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = "";
    [Parameter] public string? Tag { get; set; } = "span";
    [Parameter] public string? Class { get; set; }
}

@{
    string tag = string.IsNullOrWhiteSpace(Tag) ? "span" : Tag!;
    string classAttr = string.IsNullOrWhiteSpace(Class) ? "" : $" class=\"{Class}\"";
    string ariaLabel = EscapeAttr(Text ?? "");
    string[] words = (Text ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries);
}

@((MarkupString)$"<{tag}{classAttr} data-reveal-words aria-label=\"{ariaLabel}\">{BuildMarkup(words)}</{tag}>")

@code {
    private string BuildMarkup(string[] words)
    {
        System.Text.StringBuilder sb = new();
        for (int i = 0; i < words.Length; i++)
        {
            sb.Append($"<span class=\"ds-reveal-word\" style=\"--i:{i}\" aria-hidden=\"true\">");
            sb.Append(EscapeText(words[i]));
            sb.Append("</span>");
            if (i < words.Length - 1)
            {
                sb.Append(' ');
            }
        }
        return sb.ToString();
    }

    private static string EscapeText(string s)
    {
        System.Text.StringBuilder sb = new(s.Length);
        foreach (char c in s)
        {
            sb.Append(c switch
            {
                '<' => "&lt;",
                '>' => "&gt;",
                '&' => "&amp;",
                '\'' => "&#39;",
                '"' => "&quot;",
                _ => c.ToString(),
            });
        }
        return sb.ToString();
    }

    private static string EscapeAttr(string s) => EscapeText(s);
}
