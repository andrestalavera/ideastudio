@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@inject ISlugService SlugService

@* Phase D — editorial CV timeline.
   Two-column: sticky year + period label on the left, role + company +
   description + tech tags on the right. No cards, no tilt, no data-magnetic.
   The typographic hierarchy *is* the visual interest. *@

<div class="ds-ed-timeline">
    @foreach ((Experience exp, int i) in experiencesWithIds.Select((e, i) => (e, i)))
    {
        <article id="@exp.Id" class="ds-ed-exp" data-reveal style="--reveal-step:@(i % 3)">
            <header class="ds-ed-exp__header">
                <span class="ds-ed-number">@YearOf(exp)</span>
                <span class="ds-ed-mono ds-ed-exp__period">@PeriodOf(exp)</span>
            </header>
            <div class="ds-ed-exp__body">
                <h3 class="ds-ed-exp__role">@exp.Title</h3>
                <p class="ds-ed-exp__company">
                    <span>@exp.Company</span>
                    @if (FirstLocation(exp) is { Length: > 0 } loc)
                    {
                        <span class="ds-ed-exp__location">@loc</span>
                    }
                </p>
                @if (exp.Description is not null)
                {
                    <div class="ds-ed-exp__description ds-ed-body">
                        @foreach (string? paragraph in exp.Description)
                        {
                            if (!string.IsNullOrWhiteSpace(paragraph))
                            {
                                <p>@((MarkupString)paragraph)</p>
                            }
                        }
                    </div>
                }
                @if (exp.Skills is not null)
                {
                    <ul class="ds-ed-exp__tech ds-ed-mono">
                        @foreach (string? skill in exp.Skills)
                        {
                            if (!string.IsNullOrWhiteSpace(skill))
                            {
                                <li>@skill</li>
                            }
                        }
                    </ul>
                }
            </div>
        </article>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Experience> Experiences { get; set; } = Array.Empty<Experience>();
    private IReadOnlyList<Experience> experiencesWithIds = Array.Empty<Experience>();

    protected override void OnParametersSet() =>
        experiencesWithIds = Experiences
            .Select(e => e.WithGeneratedId(SlugService))
            .ToArray();

    private static string YearOf(Experience exp) =>
        exp.StartDate.Year > 1
            ? exp.StartDate.Year.ToString(System.Globalization.CultureInfo.InvariantCulture)
            : "—";

    private static string PeriodOf(Experience exp)
    {
        try
        {
            string start = exp.StartDate.ToString("MMM yyyy", System.Globalization.CultureInfo.InvariantCulture);
            bool isPresent = exp.EndDate.Date == DateTime.Today.Date;
            string end = isPresent
                ? "Present"
                : exp.EndDate.ToString("MMM yyyy", System.Globalization.CultureInfo.InvariantCulture);
            return $"{start} → {end}".ToUpperInvariant();
        }
        catch { return ""; }
    }

    private static string? FirstLocation(Experience exp) =>
        exp.Locations?.FirstOrDefault(l => !string.IsNullOrWhiteSpace(l));
}
