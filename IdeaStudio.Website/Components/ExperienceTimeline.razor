@using IdeaStudio.Website.Models
@using IdeaStudio.Website.Services
@inject ISlugService SlugService

<div class="ds-snap-timeline" role="list">
    @foreach (Experience experience in experiencesWithIds)
    {
        <div class="ds-snap-timeline__slot" role="listitem">
            <ExperienceCard Experience="@experience" />
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<Experience> Experiences { get; set; } = Array.Empty<Experience>();

    private IReadOnlyList<Experience> experiencesWithIds = Array.Empty<Experience>();

    protected override void OnParametersSet() =>
        experiencesWithIds = Experiences
            .Select(e => e.WithGeneratedId(SlugService))
            .ToArray();
}
