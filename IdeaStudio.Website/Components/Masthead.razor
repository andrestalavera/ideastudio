@using IdeaStudio.Website.Services
@using Microsoft.AspNetCore.Components.Web
@inherits LocalizedComponent
@inject ILocalizedRoute LocalizedRoute
@inject IThemeService ThemeService

<header class="ds-masthead ds-print-hidden" aria-label="Primary" @onkeydown="OnKeyDown">
    <nav class="ds-masthead-pill" aria-label="Main">
        <a class="ds-masthead-wordmark" href="@LocalizedRoute.For("home")">
            IdeaStud<span class="ds-masthead-dot">.</span>io
        </a>

        <div class="ds-masthead-nav">
            <a href="@LocalizedRoute.For("services.hub")">@servicesText</a>
            <a href="@LocalizedRoute.For("training")">@trainingText</a>
            <a href="@LocalizedRoute.For("realisations")">@realisationsText</a>
            <a href="@LocalizedRoute.For("about")">@aboutText</a>
            <a href="@LocalizedRoute.For("blog")">@blogText</a>
            <a href="@LocalizedRoute.For("cv")">@cvText</a>
            <a href="@LocalizedRoute.For("contact")">@contactText</a>
        </div>

        <button class="ds-masthead-theme" type="button"
                aria-label="@themeToggleLabel"
                title="@themeToggleLabel"
                aria-pressed="@(theme == "light" ? "true" : "false")"
                @onclick="ToggleTheme">
            <span aria-hidden="true">@(theme == "light" ? "☀" : "☾")</span>
        </button>

        <CultureSelector />

        <a class="ds-masthead-cta"
           href="https://calendly.com/andres-talavera/30min"
           target="_blank" rel="noopener"
           aria-label="@bookCallAriaText">
            @meetText <span aria-hidden="true">↗</span>
        </a>

        <button class="ds-masthead-toggle" type="button"
                @ref="toggleButton"
                aria-label="@(isMobileOpen ? closeMenuText : openMenuText)"
                aria-expanded="@(isMobileOpen ? "true" : "false")"
                aria-controls="ds-mobile-nav"
                @onclick="ToggleMobileMenu">
            @(isMobileOpen ? "✕" : "☰")
        </button>
    </nav>

    @if (isMobileOpen)
    {
        <div class="ds-masthead-backdrop" aria-hidden="true" @onclick="CloseMobileMenu"></div>
        <nav id="ds-mobile-nav" class="ds-masthead-mobile" aria-label="Mobile">
            <a href="@LocalizedRoute.For("services.hub")" @ref="firstMobileLink" @onclick="CloseMobileMenu">@servicesText</a>
            <a href="@LocalizedRoute.For("training")" @onclick="CloseMobileMenu">@trainingText</a>
            <a href="@LocalizedRoute.For("realisations")" @onclick="CloseMobileMenu">@realisationsText</a>
            <a href="@LocalizedRoute.For("about")" @onclick="CloseMobileMenu">@aboutText</a>
            <a href="@LocalizedRoute.For("blog")" @onclick="CloseMobileMenu">@blogText</a>
            <a href="@LocalizedRoute.For("cv")" @onclick="CloseMobileMenu">@cvText</a>
            <a href="@LocalizedRoute.For("contact")" @onclick="CloseMobileMenu">@contactText</a>
            <button class="ds-masthead-mobile-theme" type="button"
                    aria-pressed="@(theme == "light" ? "true" : "false")"
                    @onclick="ToggleTheme">
                <span>@themeToggleLabel</span>
                <span aria-hidden="true">@(theme == "light" ? "☀" : "☾")</span>
            </button>
        </nav>
    }
</header>

@code {
    private bool isMobileOpen;
    private ElementReference toggleButton;
    private ElementReference firstMobileLink;
    private bool focusFirstLinkOnRender;
    private bool focusToggleOnRender;
    private string theme = "dark";
    private string servicesText = "Services";
    private string trainingText = "Training";
    private string realisationsText = "Projects";
    private string aboutText = "About";
    private string blogText = "Blog";
    private string cvText = "Resume";
    private string contactText = "Contact";
    private string meetText = "Meet";
    private string bookCallAriaText = "Book a 30-minute call on Calendly (opens in a new tab)";
    private string openMenuText = "Open menu";
    private string closeMenuText = "Close menu";
    private string toLightText = "Switch to light theme";
    private string toDarkText = "Switch to dark theme";

    private string themeToggleLabel => theme == "light" ? toDarkText : toLightText;

    protected override void LoadTexts()
    {
        servicesText = LocalizationService.GetString("Nav.Services");
        trainingText = LocalizationService.GetString("Nav.Training");
        realisationsText = LocalizationService.GetString("Nav.Realisations");
        aboutText = LocalizationService.GetString("Nav.About");
        blogText = LocalizationService.GetString("Nav.Blog");
        cvText = LocalizationService.GetString("Nav.Cv");
        contactText = LocalizationService.GetString("Contact");
        meetText = LocalizationService.GetString("Nav.Meet");
        toLightText = LocalizationService.GetString("Theme.ToLight");
        toDarkText = LocalizationService.GetString("Theme.ToDark");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            theme = await ThemeService.GetThemeAsync();
            StateHasChanged();
        }

        if (focusFirstLinkOnRender)
        {
            focusFirstLinkOnRender = false;
            await firstMobileLink.FocusAsync();
        }
        else if (focusToggleOnRender)
        {
            focusToggleOnRender = false;
            await toggleButton.FocusAsync();
        }
    }

    private async Task ToggleTheme() => theme = await ThemeService.ToggleAsync();

    private void ToggleMobileMenu()
    {
        isMobileOpen = !isMobileOpen;
        if (isMobileOpen) focusFirstLinkOnRender = true;
        else focusToggleOnRender = true;
    }

    private void CloseMobileMenu()
    {
        if (!isMobileOpen) return;
        isMobileOpen = false;
        focusToggleOnRender = true;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseMobileMenu();
    }
}
