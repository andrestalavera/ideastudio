@using IdeaStudio.Website.Services
@inherits LocalizedComponent

@* Phase D — editorial hero.
   Kicker rule · serif display name · one lead sentence · three numbered
   contact links in a vertical list · scroll hint at the bottom. Avatar
   moved to the masthead (collapsed pre-hero). *@

<section class="ds-ed-hero" id="home-intro-hero">
    <div class="ds-ed-hero__grid">
        <div class="ds-ed-hero__kicker">
            <span class="ds-ed-mono">— @kickerText</span>
        </div>
        <h1 class="ds-ed-display ds-ed-hero__name">
            <RevealText Text="@firstName" Tag="span" />
            <br />
            <RevealText Text="@lastName" Tag="span" StartIndex="@firstName.Length" />
        </h1>
        <p class="ds-ed-lead ds-ed-hero__lead">@leadText</p>

        <nav class="ds-ed-hero__links" aria-label="@contactAriaText">
            <a class="ds-ed-link" href="https://linkedin.com/in/andres-talavera" target="_blank" rel="noopener">
                <span class="ds-ed-mono">01</span>
                <span>LinkedIn</span>
                <span class="ds-ed-link__arrow" aria-hidden="true">↗</span>
            </a>
            <a class="ds-ed-link" href="https://github.com/andrestalavera" target="_blank" rel="noopener">
                <span class="ds-ed-mono">02</span>
                <span>GitHub</span>
                <span class="ds-ed-link__arrow" aria-hidden="true">↗</span>
            </a>
            <a class="ds-ed-link ds-ed-link--primary"
               href="https://calendly.com/andres-talavera/30min"
               target="_blank" rel="noopener">
                <span class="ds-ed-mono">03</span>
                <span>@meetText</span>
                <span class="ds-ed-link__arrow" aria-hidden="true">↗</span>
            </a>
        </nav>
    </div>
    <div class="ds-ed-hero__scroll" aria-hidden="true">
        <span class="ds-ed-mono">@scrollText</span>
        <span class="ds-ed-hero__scroll-line"></span>
    </div>
</section>

@code {
    private const string firstName = "Andrés";
    private const string lastName = "Talavera";

    private string kickerText = "Consultant · Techlead · Formateur";
    private string leadText = "Je transforme des idées en logiciels qui marchent. .NET, Azure, mobile, web — à Lyon et à distance.";
    private string meetText = "Rencontrer";
    private string scrollText = "scroll";
    private string contactAriaText = "Contact";

    protected override void LoadTexts()
    {
        kickerText = LocalizationService.GetString("Home.HeroKicker");
        leadText = LocalizationService.GetString("Home.HeroLead");
        meetText = LocalizationService.GetString("Nav.Meet");
    }
}
