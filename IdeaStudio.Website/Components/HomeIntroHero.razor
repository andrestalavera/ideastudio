@using IdeaStudio.Website.Services
@inherits LocalizedComponent

<section class="ds-intro-hero" id="home-intro-hero">
    <div class="ds-container ds-intro-hero__inner">
        <img src="images/andres-talavera.jpeg"
             alt="@nameText"
             class="ds-intro-hero__avatar"
             width="140" height="140"
             loading="eager" />
        <p class="ds-intro-hero__kicker">@kickerText</p>
        <RevealText Text="@nameText" Tag="h1" Class="ds-intro-hero__name" />
        <p class="ds-intro-hero__lead">@leadText</p>
        <div class="ds-intro-hero__actions">
            <a class="ds-action" href="https://linkedin.com/in/andres-talavera" target="_blank" rel="noopener" aria-label="LinkedIn">
                <i class="fab fa-linkedin" aria-hidden="true"></i>
                <span>LinkedIn</span>
            </a>
            <a class="ds-action" href="https://github.com/andrestalavera" target="_blank" rel="noopener" aria-label="GitHub">
                <i class="fab fa-github" aria-hidden="true"></i>
                <span>GitHub</span>
            </a>
            <a class="ds-action ds-action--primary"
               href="https://calendly.com/andres-talavera/30min"
               target="_blank" rel="noopener"
               data-magnetic>
                <i class="fas fa-calendar" aria-hidden="true"></i>
                <span>@meetText</span>
            </a>
        </div>
    </div>
</section>

@code {
    private string nameText = "Andrés Talavera";
    private string kickerText = "Consultant · Techlead · Formateur";
    private string leadText = "Je transforme vos idées en logiciels qui marchent. .NET & Azure, techlead, formation, mobile, web.";
    private string meetText = "Rencontrer";

    protected override void LoadTexts()
    {
        kickerText = LocalizationService.GetString("Home.HeroKicker");
        leadText = LocalizationService.GetString("Home.HeroLead");
        meetText = LocalizationService.GetString("Nav.Meet");
    }
}
