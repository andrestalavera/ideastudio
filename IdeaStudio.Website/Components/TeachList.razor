@using IdeaStudio.Website.Models

@* TeachList, "Where I teach", grid of training centers.
   Used on Home §6 and CV § Formations. *@

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (Centers is not null)
    {
        int i = 0;
        foreach (TrainingCenter center in Centers)
        {
            <div class="flex flex-col gap-3 bg-surface border rounded-xl p-8 text-fg min-w-0 break-words" data-reveal style="@($"--reveal-step:{i}")">
                <h3 class="font-sans font-semibold text-subtitle text-fg m-0">@center.Name</h3>
                @if (center.Locations is not null)
                {
                    <p class="text-base leading-relaxed text-muted m-0">@string.Join(" · ", center.Locations)</p>
                }
                @if (center.Courses is not null)
                {
                    <div class="ds-tile-tags">
                        @foreach (string course in center.Courses)
                        {
                            <span class="ds-tag">@course</span>
                        }
                    </div>
                }
            </div>
            i++;
        }
    }
</div>

@code {
    [Parameter] public IEnumerable<TrainingCenter>? Centers { get; set; }
}
