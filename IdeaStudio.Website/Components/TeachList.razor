@using IdeaStudio.Website.Models

@* TeachList, "Where I teach", grid of training centers.
   Used on Home §6 and CV § Formations. *@

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
    @if (Centers is not null)
    {
        int i = 0;
        foreach (TrainingCenter center in Centers)
        {
            <Card data-reveal style="@($"--reveal-step:{i}")">
                <h3 class="card-title">@center.Name</h3>
                @if (center.Locations is not null)
                {
                    <p class="card-text">@string.Join(" · ", center.Locations)</p>
                }
                <TagList Tags="@center.Courses" />
            </Card>
            i++;
        }
    }
</div>

@code {
    [Parameter] public IEnumerable<TrainingCenter>? Centers { get; set; }
}
