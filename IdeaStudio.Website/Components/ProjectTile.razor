@using IdeaStudio.Website.Models

@* ProjectTile, image (or branded placeholder) + meta + title + summary + tags.
   Deep-links to a case study when one exists, otherwise to the live site. *@

<a class="ds-tile" href="@Href" target="@Target" rel="@Rel" data-reveal>
    <div class="ds-tile-media @(string.IsNullOrWhiteSpace(ImageUrl) ? "ds-tile-media-placeholder" : null)">
        @if (!string.IsNullOrWhiteSpace(ImageUrl))
        {
            <img src="@ImageUrl" alt="@ImageAlt" loading="lazy" decoding="async" width="960" height="600" />
        }
        else
        {
            <span class="ds-tile-placeholder-mark" aria-hidden="true">@Initials(Title)</span>
        }
        @if (!string.IsNullOrWhiteSpace(Badge))
        {
            <span class="ds-tile-badge">@Badge</span>
        }
    </div>
    <div class="ds-tile-meta">
        @if (!string.IsNullOrWhiteSpace(Type))
        {
            <span>@Type</span>
        }
        @if (!string.IsNullOrWhiteSpace(Year))
        {
            <span>· @Year</span>
        }
    </div>
    <h3 class="ds-tile-title">@Title</h3>
    @if (!string.IsNullOrWhiteSpace(Summary))
    {
        <p class="ds-tile-summary">@Summary</p>
    }
    @if (Tags is not null && Tags.Count > 0)
    {
        <div class="ds-tile-tags">
            @foreach (string tag in Tags)
            {
                <span class="ds-tag">@tag</span>
            }
        </div>
    }
</a>

@code {
    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Target { get; set; }
    [Parameter] public string? Rel { get; set; }
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string? ImageAlt { get; set; }
    [Parameter] public string? Type { get; set; }
    [Parameter] public string? Year { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Summary { get; set; }
    [Parameter] public string? Badge { get; set; }
    [Parameter] public IReadOnlyList<string>? Tags { get; set; }

    private static string Initials(string? title)
    {
        if (string.IsNullOrWhiteSpace(title)) return "·";
        string[] parts = title.Split(new[] { ' ', '-', '·' }, StringSplitOptions.RemoveEmptyEntries);
        string first = parts.Length > 0 ? parts[0][..1] : "";
        string second = parts.Length > 1 ? parts[1][..1] : "";
        return (first + second).ToUpperInvariant();
    }
}
