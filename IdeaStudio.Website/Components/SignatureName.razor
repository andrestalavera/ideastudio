@* SignatureName, renders a name as a live WebGL glyph object that emerges
   from a mesh, breathes, reacts to cursor and dissolves on scroll. A hidden
   <h1> carries the actual text for search engines and assistive tech. *@

@using System.Globalization
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="ds-signature" style="@AspectStyle" @ref="containerRef">
    <h1 class="ds-signature-sr">@Text</h1>
    <canvas class="ds-signature-canvas" @ref="canvasRef" aria-hidden="true"></canvas>
</div>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = "";
    [Parameter] public string FontFamily { get; set; } = "Inter";
    [Parameter] public int FontSizePx { get; set; } = 520;
    [Parameter] public int BlurPx { get; set; } = 36;
    [Parameter] public int EmergeMs { get; set; } = 2500;

    private ElementReference containerRef;
    private ElementReference canvasRef;
    private IJSObjectReference? module;
    private IJSObjectReference? handle;
    private double? fieldAspect;

    // Until the real glyph-field aspect is known (after the async mount), the
    // SCSS fallback (5/1, 4/1 on phones) applies. Once known, drive it via the
    // CSS custom property so the typeface's true proportions aren't stretched.
    private string AspectStyle =>
        fieldAspect is { } a
            ? $"--sig-aspect: {a.ToString(CultureInfo.InvariantCulture)}"
            : string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./js/cinema.bundle.js");
            handle = await module.InvokeAsync<IJSObjectReference>(
                "mountSignature",
                canvasRef,
                new
                {
                    text = Text,
                    fontFamily = FontFamily,
                    fontSizePx = FontSizePx,
                    blurPx = BlurPx,
                    emergeMs = EmergeMs
                });

            // The WebGL fallback handles don't expose getFieldAspect — guard it.
            try
            {
                fieldAspect = await handle.InvokeAsync<double>("getFieldAspect");
                if (fieldAspect is > 0) StateHasChanged();
            }
            catch (JSException) { /* fallback handle, keep SCSS default aspect */ }
        }
        catch (JSDisconnectedException) { /* runtime gone, ignore */ }
    }

    public async ValueTask DisposeAsync()
    {
        try { if (handle is not null) await handle.InvokeVoidAsync("dispose"); } catch { }
        try { if (handle is not null) await handle.DisposeAsync(); } catch { }
        try { if (module is not null) await module.DisposeAsync(); } catch { }
    }
}
