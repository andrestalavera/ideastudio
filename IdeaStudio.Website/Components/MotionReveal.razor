@* Thin wrapper: renders a div with [data-reveal]. IntersectionObserver in
   interactions/reveals.js toggles `is-revealed`; SCSS handles the animation.
   Parameters Kind / DelayMs / StaggerMs / Selector are kept for API
   compatibility with earlier callers (no-op now). *@

<div class="@BuildClasses()" data-reveal>
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Kind { get; set; } = "fade-up";
    [Parameter] public double DelayMs { get; set; } = 0;
    [Parameter] public double StaggerMs { get; set; } = 80;
    [Parameter] public string? Selector { get; set; }
    [Parameter] public string? Class { get; set; }

    private string BuildClasses() => string.IsNullOrWhiteSpace(Class) ? string.Empty : Class!;
}
