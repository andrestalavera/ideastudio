@inject IJSRuntime JS
@implements IAsyncDisposable

<div @ref="rootRef" class="ds-constellation" aria-hidden="true">
    <div class="ds-constellation__parallax" @ref="parallaxRef">
        <svg class="ds-constellation__svg" viewBox="0 0 1000 600" preserveAspectRatio="xMidYMid slice" role="presentation">
            <defs>
                <radialGradient id="ds-constellation-node-gradient" cx="50%" cy="50%" r="50%">
                    <stop offset="0%" stop-color="#ffffff" stop-opacity="1" />
                    <stop offset="40%" stop-color="#7dd3fc" stop-opacity="1" />
                    <stop offset="100%" stop-color="#5eead4" stop-opacity="0" />
                </radialGradient>
            </defs>

            <!-- Edges -->
            <line class="ds-constellation__line" x1="180" y1="120" x2="820" y2="150" />
            <line class="ds-constellation__line" x1="820" y1="150" x2="860" y2="430" />
            <line class="ds-constellation__line" x1="860" y1="430" x2="500" y2="500" />
            <line class="ds-constellation__line" x1="500" y1="500" x2="140" y2="420" />
            <line class="ds-constellation__line" x1="140" y1="420" x2="100" y2="260" />
            <line class="ds-constellation__line" x1="100" y1="260" x2="180" y2="120" />
            <line class="ds-constellation__line" x1="500" y1="500" x2="820" y2="150" />
            <line class="ds-constellation__line" x1="500" y1="500" x2="180" y2="120" />

            <!-- Nodes (each wrapped in a group for hover) -->
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="180" cy="120" r="5" />
                <text class="ds-constellation__label" x="195" y="118">.NET 10</text>
            </g>
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="820" cy="150" r="6" />
                <text class="ds-constellation__label" x="835" y="148">Azure</text>
            </g>
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="100" cy="260" r="4" />
                <text class="ds-constellation__label" x="115" y="258">C#</text>
            </g>
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="860" cy="430" r="5" />
                <text class="ds-constellation__label" x="875" y="428">Blazor</text>
            </g>
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="140" cy="420" r="4" />
                <text class="ds-constellation__label" x="155" y="418">K8s</text>
            </g>
            <g class="ds-constellation__node-group">
                <circle class="ds-constellation__node" cx="500" cy="500" r="5" />
                <text class="ds-constellation__label" x="515" y="498">Teaching</text>
            </g>
        </svg>
    </div>
</div>

@code {
    private ElementReference rootRef;
    private ElementReference parallaxRef;
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/constellation.js");
            await module.InvokeVoidAsync("attach", rootRef, parallaxRef);
        }
        catch
        {
            // If JS fails to load the constellation is still rendered (static).
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try { await module.InvokeVoidAsync("detach"); } catch { }
            try { await module.DisposeAsync(); } catch { }
        }
    }
}
