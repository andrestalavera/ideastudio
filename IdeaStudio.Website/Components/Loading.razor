@inherits LocalizedComponent

<div id="loading-overlay-mainlayout" class="loading-overlay" style="position: fixed; inset: 0; width: 100%; height: 100%; z-index: 1050;">
    <div class="loading-content" style="display: flex; align-items: center; justify-content: center; height: 100%;">
        <article class="ds-card" style="text-align: center; padding: 3rem;">
            <div class="ds-card__body ds-stack">
                <div class="spinner-border" role="status" aria-label="@loadingText" style="margin-inline: auto;">
                    <span class="visually-hidden">@loadingText</span>
                </div>
                <h1 class="ds-h3" style="margin: 0;">IdeaStud.io</h1>
                <p style="margin: 0;">@loadingAmazingContentText</p>
            </div>
        </article>
    </div>
</div>

@code {
    private string loadingText = "Loading...";
    private string loadingAmazingContentText = "Loading amazing experience...";

    protected override void LoadTexts()
    {
        loadingText = LocalizationService.GetString("Loading");
        loadingAmazingContentText = LocalizationService.GetString("LoadingAmazingContent");
    }
}
